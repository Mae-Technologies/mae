# .env
#
# This file is sourced by init_db.sh (if present). Any variables not set here
# will fall back to defaults defined in init_db.sh.
#
# SQLx notes:
# - sqlx uses DATABASE_URL by default for `sqlx database create` and `sqlx migrate run`
# - the application should use APP_DATABASE_URL at runtime
# - TABLE_CREATOR_DATABASE_URL is optional (only if you provision tables at runtime)

# -----------------------------------------------------------------------------
# Migrations path
# -----------------------------------------------------------------------------
ADMIN_MIGRATIONS_PATH=admin_migrations
APP_MIGRATIONS_PATH=migrations
# -----------------------------------------------------------------------------
# Database identity / networking
# -----------------------------------------------------------------------------
DB_PORT=2345
APP_DB_NAME=test_mae

# -----------------------------------------------------------------------------
# Postgres bootstrap superuser (used only by init_db.sh to create roles/db)
# -----------------------------------------------------------------------------
SUPERUSER=postgres
SUPERUSER_PWD=password

# -----------------------------------------------------------------------------
# LOGIN roles created by init_db.sh (these are actual database users)
# -----------------------------------------------------------------------------
# Used by SQLx migrations
MIGRATOR_USER=db_migrator
MIGRATOR_PWD=migrator_secret

# Used by the application at runtime (inherits app_user via GRANT in init_db.sh)
APP_USER=app
APP_USER_PWD=secret

# Optional: only if you create tables at runtime (inherits table_creator via GRANT)
TABLE_PROVISIONER_USER=table_provisioner
TABLE_PROVISIONER_PWD=provisioner_secret

# -----------------------------------------------------------------------------
# Connection strings
# -----------------------------------------------------------------------------
# Used by `sqlx database create` and `sqlx migrate run`
DATABASE_URL=postgres://$MIGRATOR_USER:$MIGRATOR_PWD@127.0.0.1:$DB_PORT/$APP_DB_NAME

# Used by the application at runtime
APP_DATABASE_URL=postgres://$APP_USER:$APP_USER_PWD@127.0.0.1:$DB_PORT/$APP_DB_NAME

# Optional: provisioning connection (restricted; do not use for normal app queries)
TABLE_CREATOR_DATABASE_URL=postgres://$TABLE_PROVISIONER_USER:$TABLE_PROVISIONER_PWD@127.0.0.1:$DB_PORT/$APP_DB_NAME
